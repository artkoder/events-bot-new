# Development Mode
# Установите DEV_MODE=1 для локальной разработки с polling
# Оставьте пустым или установите 0 для продакшен режима с webhook
DEV_MODE=1

# Telegram Bot Token
# Получите токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin chat (для алертов/отчётов scheduled jobs)
# Узнайте ID чата через /getid или логи бота
ADMIN_CHAT_ID=

# OpenAI API Token (для LLM операций)
# FOUR_O_TOKEN=sk-...

# Event parsing backend (VK/TG text -> structured drafts)
# По умолчанию используется 4o, но можно подготовиться к отключению OpenAI и переключиться на Gemma:
# EVENT_PARSE_LLM=gemma
# (значения: 4o|gemma)
# EVENT_PARSE_LLM=4o
# EVENT_PARSE_GEMMA_MODEL=gemma-3-27b-it
# EVENT_PARSE_GEMMA_MAX_TOKENS=2200

# Google AI Studio (Gemma/Gemini)
GOOGLE_API_KEY=

# Telegram Monitoring (Telethon)
TG_SESSION=
TG_API_ID=
TG_API_HASH=

# Kaggle API (для запуска kernels через API)
KAGGLE_USERNAME=
KAGGLE_KEY=
# KAGGLE_CONFIG_DIR=/path/to/kaggle/config

# Telegram Monitoring schedule (опционально)
ENABLE_TG_MONITORING=0
TG_MONITORING_TIME_LOCAL=23:40
TG_MONITORING_TZ=Europe/Kaliningrad

# Telegram Monitoring (Kaggle / Telethon) rate limit tuning (опционально)
# TG_MONITORING_DELAY_MIN=0.8
# TG_MONITORING_DELAY_MAX=2.2
# TG_MONITORING_SOURCE_PAUSE_MIN=2
# TG_MONITORING_SOURCE_PAUSE_MAX=6
# TG_MONITORING_FLOOD_SLEEP_THRESHOLD=600
# TG_MONITORING_FLOOD_WAIT_MAX=1800
# TG_MONITORING_FLOOD_MAX_RETRIES=4
# TG_MONITORING_FLOOD_WAIT_JITTER_MIN=6
# TG_MONITORING_FLOOD_WAIT_JITTER_MAX=18

# Kaggle recovery (опционально, но полезно на проде)
# ENABLE_KAGGLE_RECOVERY=1
# KAGGLE_RECOVERY_INTERVAL_MINUTES=5

# Supabase (опционально; без него часть логов/фич отключится)
SUPABASE_URL=
SUPABASE_KEY=
# Для RPC (rate-limit gateway) обычно нужен service role:
# SUPABASE_SERVICE_KEY=
# Если RPC лежит не в `public`, выставьте схему (PostgREST Content-Profile):
# SUPABASE_SCHEMA=public
# SUPABASE_DISABLED=1

# LLM gateway strict mode: если Supabase RPC недоступен (PGRST202), не делаем bypass на GOOGLE_API_KEY.
# GOOGLE_AI_ALLOW_RESERVE_FALLBACK=0

# Production Webhook (только для продакшена)
# WEBHOOK_URL=https://your-domain.com

# Optional settings
# DB_PATH=/data/db.sqlite

# Для тестирования с продакшн-данными локально:
# 1. Скачайте снимок БД: ./scripts/sync_prod_db.sh
# 2. Используйте снимок: DB_PATH=./db_prod_snapshot.sqlite
# 3. Запустите в режиме разработки: DEV_MODE=1

# PORT=8080
